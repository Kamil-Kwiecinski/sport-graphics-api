# URL istniejącego screenshot-service (Railway)
SCREENSHOT_SERVICE_URL=https://screenshot-service-production-85f1.up.railway.app/screenshot

# Basic auth do screenshot-service (jeśli wymaga). Zostaw puste jeśli bez auth.
SCREENSHOT_AUTH_USER=
SCREENSHOT_AUTH_PASS=

# Opcjonalny shared secret — jeśli ustawisz, /api/render wymaga header X-API-Key
API_KEY=
